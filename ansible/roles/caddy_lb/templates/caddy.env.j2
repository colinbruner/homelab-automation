# Caddy environment file — loaded by systemd, never committed to git
# Managed by Ansible — do not edit manually

CLOUDFLARE_API_TOKEN={{ cloudflare_api_token }}
POCKET_ID_CLIENT_ID={{ caddy_lb_oidc_client_id }}
POCKET_ID_CLIENT_SECRET={{ caddy_lb_oidc_client_secret }}
POCKET_ID_ISSUER_URL={{ caddy_lb_oidc_issuer_url }}
# Random 32+ char key used to sign and verify Caddy auth portal JWT cookies.
# Must be consistent across caddy restarts. Store in 1Password.
CADDY_AUTH_KEY={{ caddy_lb_auth_key }}
